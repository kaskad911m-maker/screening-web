# 1) Токен от @BotFather (Telegram)
TELEGRAM_BOT_TOKEN=paste_here

# 2) Ключ API нейросети (один из вариантов ниже)

# Вариант A — OpenAI (https://platform.openai.com/api-keys)
CHAT_API_URL=https://api.openai.com/v1/chat/completions
CHAT_API_KEY=sk-...
CHAT_MODEL=gpt-4o-mini

# Вариант B — OpenRouter (https://openrouter.ai/keys) — раскомментируй и подставь:
# CHAT_API_URL=https://openrouter.ai/api/v1/chat/completions
# CHAT_API_KEY=sk-or-v1-...
# CHAT_MODEL=openai/gpt-4o-mini

# 3) Файл со стилем (скопируй tone-of-voice.md из папки урока 2 или отредактируй этот)
TONE_FILE=./tone-of-voice.md

# 4) Опционально: «мультиагент» = два запроса к API (план → пост). 0 = один запрос, быстрее и дешевле
USE_MULTISTEP=0

# 5) Урок 4 модуля 4 — кнопка «Тренды» в боте
# Кратко опиши нишу (для подбора тем и для Tavily-запроса):
# NICHE_HINT=цифровой скрининг, вайбкодинг, лендинги для экспертов

# Опционально: ключ tavily.com (в запрос уходит как Authorization: Bearer …)
# TAVILY_API_KEY=tvly-...
